generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model user {
  id       String    @id @default(uuid())
  name     String
  email    String    @unique
  password String
  rooms    Room[]
  message  message[]
}

model Room {
  id       String    @id @default(uuid())
  slug     String    @unique
  password String?
  adminId  String
  admin    user      @relation(fields: [adminId], references: [id])
  message  message[]
}

model message {
  id           String @id @default(uuid())
  Message      String
  roomId       String
  senderId     String
  roomMessages Room   @relation(fields: [roomId], references: [id])
  userMessage  user   @relation(fields: [senderId], references: [id])
}
